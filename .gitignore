# [VOLCAN ENGINE - GIT OBLIVION PROTOCOL]

# --- BINARIOS Y COMPILACIÓN ---
bin/
out/
target/
Volcan-Engine-*/
*.class
*.jar
*.war
*.ear
bin_jmh/
src_jmh_generated/

# --- ARTEFACTOS NATIVOS ---
*.so
*.dll
*.dylib
*.exe
*.obj

# Permitir librerias estaticas del motor
!lib/*.jar
!lib/*.dll

# --- ESTADO Y TELEMETRÍA (VAULT) ---
*.vault
*.log
*.dump
telemetry_cache/

# --- CONFIGURACIÓN DE ENTORNO ---
.env
.gemini/
.idea/
.vscode/
*.iml
.DS_Store

# Secret Configuration Files
*.secrets.properties
volcanengine.secrets.properties
.env.local
.env.production
credentials.*
secrets.*
